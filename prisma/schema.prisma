// All tables live in PostgreSQL `public` only. Use DATABASE_URL without `?schema=…`
// (see `.env.example`) so Prisma Client and migrations never target another schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlanConfig {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique  // "free" | "paid" | "plan_onemonth" etc

  // Limits
  evalTotal     Int?          // lifetime cap (free only); null = unlimited
  evalHourly    Int?
  evalDaily     Int?
  evalMonthly   Int?
  umlDiagrams   Int
  noteMaxLength Int
  problemsCount Int?          // null = unlimited

  // Pricing (null for free/paid base plans)
  priceInr      Int?
  months        Int?          // null = free, 0 = lifetime
  tag           String?       // "RECOMMENDED" etc
  active        Boolean  @default(true)

  updatedAt     DateTime @updatedAt
  users         User[]
  payments      Payment[]

  @@map("plan_configs")
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String?
  password   String?
  provider   String    @default("credentials")
  apiKey     String?
  aiModel    String?
  isPaid     Boolean   @default(false)
  planExpiry DateTime?
  planId     String?   // FK → PlanConfig.id; null treated as "free"
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  submissions    Submission[]
  evaluationLogs EvaluationLog[]
  topicNotes     TopicNote[]
  diagrams       Diagram[]
  payments       Payment[]
  planConfig     PlanConfig? @relation(fields: [planId], references: [id])

  @@map("users")
}

model Payment {
  id                  String   @id @default(cuid())
  userId              String
  planConfigId        String
  razorpayOrderId     String   @unique
  razorpayPaymentId   String   @unique
  amountInr           Int
  paidAt              DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  planConfig PlanConfig @relation(fields: [planConfigId], references: [id])

  @@map("payments")
}

// Created when the Razorpay order is created — lets webhook identify user+plan without relying on Razorpay notes
model RazorpayOrder {
  id             String   @id @default(cuid())
  razorpayId     String   @unique  // order_xxx from Razorpay
  userId         String
  planSlug       String            // e.g. "plan_threemonth"
  amountInr      Int
  createdAt      DateTime @default(now())

  @@map("razorpay_orders")
}

// Raw webhook log — every hit saved regardless of signature validity
model WebhookLog {
  id          String   @id @default(cuid())
  source      String   @default("razorpay")
  event       String?             // e.g. "payment.captured"
  payload     String              // raw JSON body
  sigValid    Boolean
  createdAt   DateTime @default(now())

  @@map("webhook_logs")
}

model EvaluationLog {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  code      String
  language  String   @default("java")
  score     Int
  feedback  String   // JSON EvalResult
  modelUsed String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("evaluation_logs")
}

model TopicNote {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  content   String   @default("")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@map("topic_notes")
}

model Diagram {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Untitled Diagram")
  nodes     String   // JSON
  edges     String   // JSON
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("diagrams")
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  answer    String
  completed Boolean  @default(false)
  score     Int?
  feedback  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@map("submissions")
}
