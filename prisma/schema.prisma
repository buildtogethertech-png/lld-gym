// All tables live in PostgreSQL `public` only. Use DATABASE_URL without `?schema=…`
// (see `.env.example`) so Prisma Client and migrations never target another schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  password    String?
  provider    String   @default("credentials")
  apiKey      String?
  aiModel     String?
  isPaid      Boolean  @default(false)
  planType    String?  // "sixmonth" | "lifetime"
  planExpiry  DateTime?
  paidAt      DateTime?
  razorpayPaymentId String?
  razorpayOrderId   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions    Submission[]
  evaluationLogs EvaluationLog[]
  topicNotes     TopicNote[]
  diagrams       Diagram[]

  @@map("users")
}

model EvaluationLog {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  code      String
  language  String   @default("java")
  score     Int
  feedback  String   // JSON EvalResult
  modelUsed String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("evaluation_logs")
}

model TopicNote {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  content   String   @default("")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@map("topic_notes")
}

model Diagram {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Untitled Diagram")
  nodes     String   // JSON
  edges     String   // JSON
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("diagrams")
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  answer    String
  completed Boolean  @default(false)
  score     Int?
  feedback  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
  @@map("submissions")
}
