{
  "name": "reach-lld",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev -p 3001",
    "fresh": "rm -rf .next && next dev -p 3001",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:studio": "prisma studio",
    "migration:dev": "NODE_ENV=development npx prisma migrate deploy && npx prisma generate",
    "migration:staging": "DEPLOY_MIGRATE_TARGET=staging npx prisma migrate deploy && npx prisma generate",
    "migration:production": "NODE_ENV=production npx prisma migrate deploy && npx prisma generate",
    "deploy:vercel:staging": "bash scripts/deploy-vercel.sh staging",
    "deploy:vercel:production": "bash scripts/deploy-vercel.sh production",
    "deploy:vercel": "bash scripts/deploy-vercel.sh production",
    "e2e:seed": "NODE_ENV=development npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/e2e-seed-users.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:headless": "E2E_HEADLESS=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^6.19.3",
    "@xyflow/react": "^12.10.2",
    "bcryptjs": "^3.0.3",
    "next": "^14.2.35",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "openai": "^6.33.0",
    "prisma": "^6.19.3",
    "razorpay": "^2.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  }
}
